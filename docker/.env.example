# ============================================================================
# Environment inventory for ONE site. Copy to `.env` for local compose use.
#
#   cp .env.example .env
#
# In production, the per-site values live in AWS Secrets Manager / SSM and are
# injected into the ECS task — never committed. This file documents the full
# contract: give the template image these vars and it becomes a specific site.
# ============================================================================

# --- Database (content) -----------------------------------------------------
# Local compose uses the bundled Postgres. In prod this is the site's RDS DB,
# e.g. postgresql://user:pass@portfolio-db.xxx.rds.amazonaws.com:5432/payload_markmusil
DATABASE_URL=postgresql://payload:payload@db:5432/payload

# --- Payload secret (MUST be stable per site — see PROPOSED_APP_CHANGES.md #2)
# Generate once per site:  openssl rand -base64 32
# Then never change it, or sessions/encrypted fields break on container replace.
PAYLOAD_SECRET=dev-secret-change-me

# Public URL the site is served at (used by Payload for links/CORS).
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# --- Media storage (S3 / MinIO) ---------------------------------------------
S3_BUCKET=media
# Per-site prefix so many sites can share one bucket (Model A). e.g. "markmusil/"
S3_PREFIX=
# Set S3_ENDPOINT for MinIO/local or non-AWS S3; LEAVE BLANK for real AWS S3
# (in AWS, prefer an IAM task role over static keys below).
S3_ENDPOINT=http://minio:9000
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# --- Builder.io -------------------------------------------------------------
# Per-site Builder space API key. Public (client-side) key is fine to expose.
NEXT_PUBLIC_BUILDER_API_KEY=

# --- Runtime knobs ----------------------------------------------------------
# true = run DB migrations on container start; set false when a separate
# one-off migration task owns migrations (see docker-entrypoint.sh).
RUN_MIGRATIONS=true
NODE_ENV=production
